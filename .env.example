# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Bruno Autopilot
ENVIRONMENT=production
DEBUG=false

# ─── Database / Redis ──────────────────────────────────────────────────────────
# In Docker these are overridden by docker-compose to point at the db/redis services.
DATABASE_URL=postgresql+asyncpg://bruno:bruno@localhost:5432/bruno_autopilot
REDIS_URL=redis://localhost:6379/0
POSTGRES_PASSWORD=bruno

# ─── Anthropic (Claude) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8192

# ─── Supabase (Bruno project — where published posts are written) ───────────────
SUPABASE_URL=https://gwlstrqktsvumpbiwoqu.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# ─── Brand / market ─────────────────────────────────────────────────────────────
BRAND_NAME=Bruno
SITE_URL=https://brunomind.com
TARGET_MARKET=US

# ─── Publishing cadence ─────────────────────────────────────────────────────────
PUBLISH_TIME=06:00
PUBLISH_TIMEZONE=America/New_York
POSTS_PER_RUN=1
MIN_QUEUED_KEYWORDS=10

# ─── Content guardrails ─────────────────────────────────────────────────────────
MIN_BODY_WORDS=700
REQUIRE_CRISIS_DISCLAIMER=true

# ─── Google Search Console (later phase — leave blank for launch) ───────────────
GOOGLE_SERVICE_ACCOUNT_JSON=
GSC_SITE_URL=
