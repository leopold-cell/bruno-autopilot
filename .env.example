# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Bruno Autopilot
ENVIRONMENT=production
DEBUG=false

# ─── Database / Redis ──────────────────────────────────────────────────────────
# Hostnames are the docker-compose service names (db / redis). For local dev WITHOUT
# Docker, change these to localhost:5433 / localhost:6380 (the published ports).
DATABASE_URL=postgresql+asyncpg://bruno:bruno@db:5432/bruno_autopilot
REDIS_URL=redis://redis:6379/0
POSTGRES_PASSWORD=bruno

# ─── Anthropic (Claude) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=8192

# ─── Supabase (Bruno project — where published posts are written) ───────────────
SUPABASE_URL=https://ayvaceirodkskkloisep.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ─── DataForSEO (real keyword volume + difficulty; optional, falls back to Claude) ──
DATAFORSEO_LOGIN=your-dataforseo-email
DATAFORSEO_PASSWORD=your-dataforseo-password

# ─── MailerLite (weekly digest — best post of the week) ─────────────────────────
MAILERLITE_API_KEY=eyJ...
MAILERLITE_GROUP_ID=189988925401466523
MAILERLITE_FROM_EMAIL=hi@brunomind.com
MAILERLITE_FROM_NAME=Bruno
WEEKLY_DIGEST_ENABLED=true
WEEKLY_DIGEST_DAY=sun
WEEKLY_DIGEST_TIME=09:00

# ─── Brand / market ─────────────────────────────────────────────────────────────
BRAND_NAME=Bruno
SITE_URL=https://brunomind.com
TARGET_MARKET=US

# ─── Publishing cadence ─────────────────────────────────────────────────────────
PUBLISH_TIME=06:00
PUBLISH_TIMEZONE=America/New_York
POSTS_PER_RUN=1
MIN_QUEUED_KEYWORDS=10

# ─── Content guardrails ─────────────────────────────────────────────────────────
MIN_BODY_WORDS=700
REQUIRE_CRISIS_DISCLAIMER=true

# ─── Google Search Console (later phase — leave blank for launch) ───────────────
GOOGLE_SERVICE_ACCOUNT_JSON=
GSC_SITE_URL=
